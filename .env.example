# .env.example — copy to .env.local and fill in values
# Do NOT commit real secrets.

# Turso DB (local workaround: leave as "file:./dev.db" for SQLite file)
DATABASE_URL=file:./dev.db
# DATABASE_URL=libsql://your-db-name.turso.io   # production Turso URL
DATABASE_AUTH_TOKEN=                              # Turso auth token (leave empty for local)

# Supabase (optional — auth/storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=                        # Server-side only — never expose to client

# Vercel (CI/CD — set in GitHub Secrets, not in .env)
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
