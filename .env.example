# .env.example — copy to .env.local and fill in real values
# NEVER commit .env.local or any file containing real secrets.
# All variables marked [server] are server-side only — never expose to the browser.
# All variables marked [public] are safe to expose to the browser (NEXT_PUBLIC_ prefix).

# ─────────────────────────────────────────────
# DATABASE — Turso (libsql)
# ─────────────────────────────────────────────
# Local development workaround: leave DATABASE_URL as "file:./dev.db"
# to use a local SQLite file with zero credentials required.
# For production, set to your Turso database URL.
#
# [server] Turso database URL (local: file:./dev.db | remote: libsql://<db>.turso.io)
DATABASE_URL=file:./dev.db
#
# [server] Turso auth token — required for remote Turso DB; leave empty for local SQLite
DATABASE_AUTH_TOKEN=

# ─────────────────────────────────────────────
# AUTH & STORAGE — Supabase
# ─────────────────────────────────────────────
# Leave blank locally — the app falls back to a guest session automatically.
# Fill in when you have a Supabase project set up.
#
# [public] Your Supabase project URL (e.g. https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=
#
# [public] Supabase anonymous/public key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=
#
# [server] Supabase service-role key — has full DB access; NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────
# CI/CD — Vercel (set in GitHub Secrets, not here)
# ─────────────────────────────────────────────
# These are consumed by the GitHub Actions workflow (.github/workflows/ci.yml).
# Add them as repository secrets in GitHub → Settings → Secrets → Actions.
# Do NOT put real values in this file.
#
# [ci] Vercel personal access token (vercel.com → Account Settings → Tokens)
# VERCEL_TOKEN=
#
# [ci] Vercel organization/team ID (found in vercel.com → Team Settings → General)
# VERCEL_ORG_ID=
#
# [ci] Vercel project ID (found in vercel.com → Project Settings → General)
# VERCEL_PROJECT_ID=

# ─────────────────────────────────────────────
# APP CONFIG (optional overrides)
# ─────────────────────────────────────────────
# [public] Base URL of the deployed app — used for absolute URL generation
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
#
# [server] Node environment — "development" | "test" | "production"
# NODE_ENV=development
